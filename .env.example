# ─────────────────────────────────────────────────────────────────
# Copia questo file in .env e compila i valori reali
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=football
POSTGRES_PASSWORD=football123
POSTGRES_DB=football_scout

# ── FastAPI ─────────────────────────────────────────────────────
SECRET_KEY=cambia-questa-chiave-in-produzione
DEBUG=true

# ── API Esterne (dati calciatori) ────────────────────────────────
# Ottieni chiave gratuita su https://www.api-football.com/
API_FOOTBALL_KEY=

# Football-Data.org - gratuito con registrazione
# https://www.football-data.org/
FOOTBALL_DATA_KEY=

# ── Frontend ────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Produzione ──────────────────────────────────────────────────
PROD_API_URL=https://api.tuodominio.com
